# Copy to .env and fill in. `.env` is gitignored — never commit real keys.

# Amplifier Health API (https://docs.amplifierhealth.com)
AMPLIFIER_ACCOUNT_ID=
AMPLIFIER_API_KEY=
# AMPLIFIER_BASE_URL=https://api.amplifierhealth.com

# Anthropic (Claude agents)
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Demo/config knobs (all optional) ---
# MOCK_CLAUDE=1            # canned agent output, no Anthropic calls
# MOCK_WHISPER=1           # skip transcription
# AMPLIFIER_CACHE=warm     # warm = reuse cached results | record = live + cache | off
# SPEED=20                 # audio replay speed multiplier
# WHISPER_MODEL=base       # faster-whisper model size
# DATA_DIR=data            # patient store root
